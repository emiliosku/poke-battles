# Build the Showdown dex/move/ability data files that ``pokecore.pokedex``
# reads at runtime. The data lives in upstream smogon/pokemon-showdown
# and is regenerated by ``node build``; the resulting ``dist/data/`` is
# what ``packages/core/src/pokecore/pokedex.py`` loads via
# ``Path(__file__).resolve().parents[3] / "engine" / "server" / "dist" / "data" / "pokedex.js"``.
# Without this stage ``load_pokedex()`` returns ``()`` and the
# ``/api/sprites/status`` endpoint reports 0 species.
#
# The data is gitignored at the repo root (``packages/engine/server/``)
# because it's a build artifact, so it has to be generated here rather
# than copied from the build context.
FROM node:20-alpine AS showdown-data

ARG SHOWDOWN_REF=master

RUN apk add --no-cache git python3 make g++ \
    && git clone --depth=1 --branch=${SHOWDOWN_REF} \
        https://github.com/smogon/pokemon-showdown.git /build \
    && cd /build \
    && npm ci --no-audit --no-fund \
    && node build \
    && cp -r dist/data /showdown-data

FROM python:3.12-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates nodejs \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 poke && mkdir /app && chown poke:poke /app
WORKDIR /app

COPY pyproject.toml uv.lock models.yaml ./
COPY packages ./packages

COPY --from=showdown-data /showdown-data /app/packages/engine/server/dist/data

RUN pip install uv && \
    uv pip install --system \
        -e ./packages/core \
        -e ./packages/engine \
        -e ./packages/llm \
        -e ./packages/api \
        "psycopg2-binary>=2.9.0"

RUN chown -R poke:poke /app

USER 100:101

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -fsS http://localhost:8000/health || exit 1

CMD ["uvicorn", "pokeapi.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
